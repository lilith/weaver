# Template for local setup. Committed to the public repo.
# Copy to `.env` and fill the blank SECRETS below.
#
#   cp .env.example .env
#   # then edit .env with your real keys
#
# Public values (R2 account ID, bucket names, endpoints, public bucket URLs,
# domain, sender email) are published here intentionally — they don't
# authenticate anything. Everything blank is a secret you must provide.

# === Anthropic (Claude Opus 4.7, Sonnet 4.6, Haiku 4.5) ===
# SECRET: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# === fal.ai (FLUX.2 [pro] image gen, FLUX Kontext edits) ===
# SECRET: https://fal.ai/dashboard/keys
FAL_KEY=

# === Cloudflare R2 (S3-compatible object storage) ===
R2_ACCOUNT_ID=338ad3b06716695d6e2c81c864e387d8

# SECRETS: Cloudflare dashboard → R2 → Manage R2 API Tokens → create token "weaver-dev"
#   scope: Object Read & Write on both buckets below
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Art bucket — scene art, portraits, biome refs, theme ornaments
R2_IMAGES_BUCKET=weaver-images
R2_IMAGES_ENDPOINT=https://338ad3b06716695d6e2c81c864e387d8.r2.cloudflarestorage.com/weaver-images
R2_IMAGES_PUBLIC_URL=https://pub-8422ad246fe048628eff9d8f2d72146d.r2.dev

# General bucket — chronicle exports, long-tail generated content, cache blobs
R2_CACHE_BUCKET=weaver-general
R2_CACHE_ENDPOINT=https://338ad3b06716695d6e2c81c864e387d8.r2.cloudflarestorage.com/weaver-general
R2_CACHE_PUBLIC_URL=https://pub-01eab3f7aa66406cad7ad759e82d9d97.r2.dev

# === Resend (magic-link email via Better Auth) ===
# SECRET: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Weaver <noreply@theweaver.quest>

# === Convex (auto-populated on first `npx convex dev`) ===
CONVEX_DEPLOYMENT=
PUBLIC_CONVEX_URL=

# === App ===
PUBLIC_APP_URL=https://theweaver.quest
APP_WHITELIST_EMAILS=

# Public R2 images bucket URL — client-side, used by the art-curation
# wardrobe to build blob image URLs from content hashes. Same value as
# R2_IMAGES_PUBLIC_URL above; the `PUBLIC_` prefix is what exposes it
# to SvelteKit's browser bundle. Must also be set on the Cloudflare
# Pages project env (Dashboard → Pages → weaver → Settings → Env vars).
PUBLIC_R2_IMAGES_URL=https://pub-8422ad246fe048628eff9d8f2d72146d.r2.dev

# === Optional ===
# Sentry (error monitoring). Create a SvelteKit project at sentry.io and paste the
# DSN here. Both client and server read this as PUBLIC_SENTRY_DSN.
PUBLIC_SENTRY_DSN=

# === Code-change proposals (spec/MODULE_AND_CODE_PROPOSALS.md) ===
# Target repo for the "/admin/code/<slug>" surface. Defaults to lilith/weaver.
# Only needed in the Convex deployment env, not local .env:
#   npx convex env set GITHUB_REPO lilith/weaver
#   npx convex env set GITHUB_REPO_PAT <fine-grained PAT w/ Issues: write>
GITHUB_REPO=lilith/weaver
GITHUB_REPO_PAT=
