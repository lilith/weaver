{
  "name": "weaver",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:convex": "vitest run tests/convex",
    "check": "pnpm -C apps/play check",
    "pre-push": "pnpm run test && pnpm run check",
    "test:loop": "node scripts/test-loop.mjs",
    "test:loop:all": "node scripts/test-loop.mjs --all",
    "push-convex": "CONVEX_DEPLOYMENT=dev:friendly-chameleon-175 convex dev --once",
    "deploy": "echo \"Error: 'npx convex deploy' targets the unused animated-dodo-350 deployment. Use 'pnpm run push-convex' to push to friendly-chameleon-175 (the one deployment backing theweaver.quest).\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@fal-ai/client": "^1.9.5",
    "@noble/hashes": "^2.2.0",
    "@weaver/engine": "workspace:*",
    "convex": "^1.35.1",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "resend": "^6.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "convex-test": "^0.0.49",
    "vitest": "^4.1.4"
  }
}
